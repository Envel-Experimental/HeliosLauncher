{
  "name": "flauncher",
  "version": "3.0.0",
  "productName": "FLauncher",
  "description": "Foxford Launcher",
  "author": "Nikita Gutsenkov (https://github.com/Envel-Experimental/)",
  "license": "SEE LICENSE IN LICENSE.txt",
  "homepage": "https://github.com/Envel-Experimental/Flauncher",
  "bugs": {
    "url": "https://github.com/Envel-Experimental/Flauncher/issues"
  },
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "bundle": "node esbuild.config.js",
    "postinstall": "patch-package",
    "dist": "electron-builder build",
    "dist:win": "npm run dist -- -w",
    "dist:mac": "npm run dist -- -m",
    "dist:linux": "npm run dist -- -l",
    "lint": "eslint .",
    "test:async": "node scripts/check_async.js",
    "test": "npm run lint && npm run test:async && jest && playwright test tests/smoke.spec.js",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:coverage": "jest --coverage",
    "test:performance": "playwright test tests/performance",
    "test:smoke": "playwright test tests/smoke.spec.js",
    "test:e2e": "playwright test tests/e2e.spec.js"
  },
  "engines": {
    "node": ">=20.x.x"
  },
  "dependencies": {
    "@sentry/electron": "^7.7.1",
    "b4a": "^1.7.5",
    "electron-updater": "^6.7.3",
    "helios-distribution-types": "^1.3.0",
    "hyperdht": "^6.29.0",
    "hyperswarm": "^4.16.0",
    "p-limit": "^7.3.0",
    "semver": "^7.7.4",
    "smol-toml": "^1.6.0",
    "udx-native": "^1.19.2"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "assert": "^2.1.0",
    "constants-browserify": "^1.0.0",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.0.0",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "msw": "^2.12.10",
    "patch-package": "^8.0.1",
    "playwright": "^1.58.2",
    "stream-http": "^3.2.0"
  },
  "overrides": {
    "@opentelemetry/core": "^2.8.0",
    "js-yaml": "^4.1.1",
    "tar": "^7.5.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Envel-Experimental/Flauncher.git"
  }
}