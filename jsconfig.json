{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "checkJs": false,
    "allowJs": true,
    "strict": false,
    "baseUrl": ".",
    "rootDirs": [".", "./app"],
    "paths": {
      "./assets/js/*": ["./app/assets/js/*"],
      "assets/*": ["app/assets/*"],
      "*": ["*", "app/*"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "build"
  ]
}
